{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceHealthChecks": [
    "http://localhost:5101",
    "http://localhost:5102",
    "http://localhost:5103",
    "http://localhost:5104",
    "http://localhost:5105"
  ],
  "ReverseProxy": {
    "Routes": {
      "authors-api": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/api/authors/{**catch-all}"
        }
      },
      "authors-api-root": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/api/authors"
        }
      },
      "authors-health": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/authors/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "books-api": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books/{**catch-all}"
        }
      },
      "books-api-root": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books"
        }
      },
      "books-health": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/books/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "loans-api": {
        "ClusterId": "loans-cluster",
        "Match": {
          "Path": "/api/loans/{**catch-all}"
        }
      },
      "loans-api-root": {
        "ClusterId": "loans-cluster",
        "Match": {
          "Path": "/api/loans"
        }
      },
      "loans-health": {
        "ClusterId": "loans-cluster",
        "Match": {
          "Path": "/loans/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "members-api": {
        "ClusterId": "members-cluster",
        "Match": {
          "Path": "/api/members/{**catch-all}"
        }
      },
      "members-api-root": {
        "ClusterId": "members-cluster",
        "Match": {
          "Path": "/api/members"
        }
      },
      "members-health": {
        "ClusterId": "members-cluster",
        "Match": {
          "Path": "/members/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "auth-api": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "auth-users-api": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "auth-users-api-root": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users"
        }
      },
      "auth-roles-api": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      },
      "auth-roles-api-root": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/roles"
        }
      },
      "auth-health": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      }
    },
    "Clusters": {
      "authors-cluster": {
        "Destinations": {
          "authors": {
            "Address": "http://localhost:5101/"
          }
        }
      },
      "books-cluster": {
        "Destinations": {
          "books": {
            "Address": "http://localhost:5102/"
          }
        }
      },
      "loans-cluster": {
        "Destinations": {
          "loans": {
            "Address": "http://localhost:5103/"
          }
        }
      },
      "members-cluster": {
        "Destinations": {
          "members": {
            "Address": "http://localhost:5104/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:5105/"
          }
        }
      }
    }
  }
}
