{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "LibraryDatabase": "Server=localhost;Database=LibraryMicroservices;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "LibraryMicroservices",
    "Audience": "LibraryMicroservices",
    "SecretKey": "LibraryMicroservices-Dev-Secret-Key-Min-32-Chars!",
    "ExpirationMinutes": 60
  },
  "Auth": {
    "UsersDataFilePath": "data/users.json",
    "RolesDataFilePath": "data/roles.json",
    "UserRolesDataFilePath": "data/userRoles.json"
  }
}
